
{
  "entities": {
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Represents a tenant (e.g., a company) using the platform.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the tenant (e.g., 'Acme Corp')."
        },
        "region": {
          "type": "string",
          "description": "The geographical region of the tenant."
        },
        "branding": {
          "type": "object",
          "description": "Custom branding for the tenant."
        }
      },
      "required": ["name", "region"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the platform.",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "tenantId": { "type": "string", "description": "Reference to Tenant." },
        "roleId": { "type": "string", "description": "Reference to Role." },
        "avatarId": { "type": "string", "description": "Reference to a placeholder image ID for the user's avatar." },
        "mfa_enabled": { "type": "boolean", "default": false },
        "status": { "type": "string", "enum": ["Active", "Invited", "Suspended"] },
        "risk": { "type": "string", "enum": ["Low", "Medium", "High"] }
      },
      "required": ["name", "email", "tenantId", "roleId", "status", "risk"]
    },
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "properties": {
        "name": { "type": "string", "enum": ["User", "Admin", "SuperAdmin"] }
      },
      "required": ["name"]
    },
    "Permission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Permission",
      "type": "object",
      "properties": {
        "key": { "type": "string", "description": "e.g. MANAGE_USERS" }
      },
      "required": ["key"]
    },
    "RolePermission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RolePermission",
      "type": "object",
      "properties": {
        "roleId": { "type": "string" },
        "permissionId": { "type": "string" }
      },
      "required": ["roleId", "permissionId"]
    },
    "Campaign": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Campaign",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["training", "phishing", "fraud"] },
        "start_date": { "type": "string", "format": "date-time" },
        "end_date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "active", "completed"] }
      },
      "required": ["name", "type", "status"]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "duration": { "type": "number", "description": "Duration in minutes." },
        "version": { "type": "string" }
      },
      "required": ["title", "duration"]
    },
    "PhishingSimulation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PhishingSimulation",
      "type": "object",
      "properties": {
        "template": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["low", "medium", "high"] },
        "scheduled_at": { "type": "string", "format": "date-time" }
      },
      "required": ["template", "difficulty"]
    },
    "FraudScenario": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FraudScenario",
      "type": "object",
      "properties": {
        "scenario_type": { "type": "string" },
        "region": { "type": "string" },
        "risk_level": { "type": "string" }
      },
      "required": ["scenario_type", "region"]
    },
    "Incident": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Incident",
      "type": "object",
      "properties": {
        "reported_by": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["open", "in_progress", "resolved", "closed"] },
        "assigned_to": { "type": "string" }
      },
      "required": ["reported_by", "category", "severity", "status"]
    },
    "Certification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Certification",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "validity_months": { "type": "number" }
      },
      "required": ["name", "validity_months"]
    },
    "AuditLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AuditLog",
      "type": "object",
      "properties": {
        "actor_id": { "type": "string" },
        "action": { "type": "string" },
        "resource": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["actor_id", "action", "resource", "timestamp"]
    },
    "TrainingModule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TrainingModule",
      "type": "object",
      "description": "Represents a training module.",
      "properties": {
        "category": { "type": "string" },
        "difficulty": { "type": "string" },
        "aiAdaptive": { "type": "boolean" },
        "duration": { "type": "number" }
      },
      "required": ["category", "difficulty", "aiAdaptive", "duration"]
    },
    "TrainingResult": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TrainingResult",
      "type": "object",
      "description": "Result of a user completing a training module.",
      "properties": {
        "userId": { "type": "string" },
        "moduleId": { "type": "string" },
        "score": { "type": "number" },
        "timeTaken": { "type": "number" },
        "riskImpact": { "type": "number" }
      },
      "required": ["userId", "moduleId", "score", "timeTaken"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "tenants/{tenantId}",
        "definition": {
          "schema": { "$ref": "#/entities/Tenant" },
          "subcollections": {
            "campaigns": { "schema": { "$ref": "#/entities/Campaign" } },
            "courses": { "schema": { "$ref": "#/entities/Course" } },
            "phishing_simulations": { "schema": { "$ref": "#/entities/PhishingSimulation" } },
            "fraud_scenarios": { "schema": { "$ref": "#/entities/FraudScenario" } },
            "incidents": { "schema": { "$ref": "#/entities/Incident" } },
            "certifications": { "schema": { "$ref": "#/entities/Certification" } },
            "audit_logs": { "schema": { "$ref": "#/entities/AuditLog" } }
          }
        }
      },
      {
        "path": "users/{userId}",
        "definition": {
          "schema": { "$ref": "#/entities/User" },
          "subcollections": {
            "trainingResults": { "schema": { "$ref": "#/entities/TrainingResult" } }
          }
        }
      },
      { "path": "roles/{roleId}", "definition": { "schema": { "$ref": "#/entities/Role" } } },
      { "path": "permissions/{permissionId}", "definition": { "schema": { "$ref": "#/entities/Permission" } } },
      { "path": "role_permissions/{rolePermissionId}", "definition": { "schema": { "$ref": "#/entities/RolePermission" } } },
      { "path": "trainingModules/{moduleId}", "definition": { "schema": { "$ref": "#/entities/TrainingModule" } } }
    ]
  }
}
