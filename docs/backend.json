
{
  "entities": {
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Represents a tenant (e.g., a company) using the platform.",
      "properties": {
        "name": { "type": "string", "description": "Name of the tenant (e.g., 'Safaricom PLC')." },
        "region": { "type": "string", "description": "The geographical region of the tenant." },
        "status": { "type": "string", "enum": ["active", "suspended", "trial", "expired"], "description": "The current status of the tenant." },
        "subscription": {
          "type": "object",
          "properties": {
            "tier": { "type": "string", "enum": ["basic", "pro", "enterprise"] },
            "startDate": { "type": "string", "format": "date-time" },
            "renewalDate": { "type": "string", "format": "date-time" },
            "maxUsers": { "type": "number" },
            "features": { "type": "array", "items": { "type": "string" } }
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "branding": {
              "type": "object",
              "properties": {
                "logoUrl": { "type": "string", "format": "uri" },
                "primaryColor": { "type": "string" },
                "secondaryColor": { "type": "string" }
              }
            },
            "security": {
              "type": "object",
              "properties": {
                "passwordPolicy": { "type": "string" },
                "mfaRequired": { "type": "boolean" },
                "sessionTimeout": { "type": "number" }
              }
            },
            "compliance": {
              "type": "object",
              "properties": {
                "regulations": { "type": "array", "items": { "type": "string" } },
                "requireCertificates": { "type": "boolean" }
              }
            }
          }
        },
        "contact": {
          "type": "object",
          "properties": {
            "adminEmail": { "type": "string", "format": "email" },
            "billingEmail": { "type": "string", "format": "email" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "stats": {
            "type": "object",
            "properties": {
                "totalUsers": { "type": "number" },
                "activeUsers": { "type": "number" },
                "completionRate": { "type": "number" },
                "avgScore": { "type": "number" }
            }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "region", "status"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the platform.",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "tenantId": { "type": "string", "description": "Primary reference to Tenant." },
        "assignedTenants": { "type": "array", "items": { "type": "string" }, "description": "Array of tenant IDs the user has access to." },
        "role": { "type": "string", "enum": ["super_admin", "tenant_admin", "department_admin", "employee"] },
        "department": { "type": "string" },
        "jobTitle": { "type": "string" },
        "employeeId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "invited", "suspended", "archived"] },
        "trainingStats": {
            "type": "object",
            "properties": {
                "completedModules": { "type": "number" },
                "totalModules": { "type": "number" },
                "avgScore": { "type": "number" },
                "lastCompleted": { "type": "string", "format": "date-time" },
                "complianceScore": { "type": "number" }
            }
        },
        "phishingStats": {
            "type": "object",
            "properties": {
                "simulatedReceived": { "type": "number" },
                "clicked": { "type": "number" },
                "reported": { "type": "number" },
                "riskScore": { "type": "string", "enum": ["low", "medium", "high", "critical"] }
            }
        },
        "preferences": {
            "type": "object",
            "properties": {
                "language": { "type": "string" },
                "notifications": { "type": "boolean" },
                "darkMode": { "type": "boolean" }
            }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "displayName", "tenantId", "role", "status"]
    },
    "TrainingModule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TrainingModule",
      "type": "object",
      "description": "Represents a training module.",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "duration": { "type": "number", "description": "Duration in minutes." },
        "content": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["video", "slides", "interactive", "document"] },
            "url": { "type": "string", "format": "uri" },
            "slides": { "type": "array", "items": { "type": "object" } },
            "transcript": { "type": "string" }
          }
        },
        "quiz": {
          "type": "object",
          "properties": {
            "questions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "question": { "type": "string" },
                  "options": { "type": "array", "items": { "type": "string" } },
                  "correctAnswer": { "type": "number" },
                  "explanation": { "type": "string" }
                }
              }
            },
            "passingScore": { "type": "number" },
            "attemptsAllowed": { "type": "number" }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "version": { "type": "string" },
            "createdBy": { "type": "string" },
            "lastUpdated": { "type": "string", "format": "date-time" },
            "tags": { "type": "array", "items": { "type": "string" } }
          }
        },
        "availability": {
          "type": "object",
          "properties": {
            "global": { "type": "boolean" },
            "tenantIds": { "type": "array", "items": { "type": "string" } },
            "tiers": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "required": ["title", "category", "difficulty", "duration"]
    },
    "UserProgress": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "UserProgress",
        "type": "object",
        "description": "Tracks a single user's progress for a single module.",
        "properties": {
            "userId": { "type": "string" },
            "moduleId": { "type": "string" },
            "tenantId": { "type": "string" },
            "status": { "type": "string", "enum": ["not_started", "in_progress", "completed", "expired"] },
            "startedAt": { "type": "string", "format": "date-time" },
            "completedAt": { "type": "string", "format": "date-time" },
            "score": { "type": "number" },
            "attempts": { "type": "array", "items": { "type": "object" } },
            "certificate": {
                "type": "object",
                "properties": {
                    "issuedAt": { "type": "string", "format": "date-time" },
                    "expiresAt": { "type": "string", "format": "date-time" },
                    "certificateId": { "type": "string" },
                    "downloadUrl": { "type": "string", "format": "uri" }
                }
            }
        },
        "required": ["userId", "moduleId", "tenantId", "status"]
    },
    "Assignment": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Assignment",
        "type": "object",
        "description": "Represents a training assignment for users.",
        "properties": {
            "tenantId": { "type": "string" },
            "moduleId": { "type": "string" },
            "assignedBy": { "type": "string" },
            "assignedTo": {
                "type": "object",
                "properties": {
                    "type": { "type": "string", "enum": ["all", "department", "group", "individual"] },
                    "department": { "type": "string" },
                    "groupId": { "type": "string" },
                    "userIds": { "type": "array", "items": { "type": "string" } }
                }
            },
            "dueDate": { "type": "string", "format": "date-time" },
            "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
            "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
            "reminderSettings": {
                "type": "object",
                "properties": {
                    "daysBefore": { "type": "array", "items": { "type": "number" } },
                    "notifications": { "type": "boolean" }
                }
            },
            "createdAt": { "type": "string", "format": "date-time" }
        },
        "required": ["tenantId", "moduleId", "assignedBy", "assignedTo", "status"]
    },
    "PhishingSimulation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PhishingSimulation",
      "type": "object",
      "properties": {
        "tenantId": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["email", "sms", "social"] },
        "template": { "type": "string" },
        "targetGroup": { "type": "object" },
        "schedule": { "type": "object" },
        "results": { "type": "object" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "sent", "completed"] }
      },
      "required": ["tenantId", "name", "type", "status"]
    },
    "Report": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Report",
        "type": "object",
        "properties": {
            "tenantId": { "type": "string" },
            "name": { "type": "string" },
            "type": { "type": "string", "enum": ["compliance", "training", "phishing", "custom"] },
            "period": { "type": "object" },
            "filters": { "type": "object" },
            "data": { "type": "object" },
            "generatedBy": { "type": "string" },
            "generatedAt": { "type": "string", "format": "date-time" },
            "downloadUrl": { "type": "string", "format": "uri" }
        },
        "required": ["tenantId", "name", "type", "generatedBy", "generatedAt"]
    },
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "properties": {
        "name": { "type": "string", "enum": ["super_admin", "tenant_admin", "department_admin", "employee"] }
      },
      "required": ["name"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "/tenants/{tenantId}": { "schema": { "$ref": "#/entities/Tenant" }, "description": "Top-level collection of tenants." },
    "/users/{userId}": { "schema": { "$ref": "#/entities/User" }, "description": "Top-level collection for all users." },
    "/trainingModules/{moduleId}": { "schema": { "$ref": "#/entities/TrainingModule" }, "description": "Global library of training modules." },
    "/userProgress/{progressId}": { "schema": { "$ref": "#/entities/UserProgress" }, "description": "Tracks user progress in modules." },
    "/assignments/{assignmentId}": { "schema": { "$ref": "#/entities/Assignment" }, "description": "Training assignments for tenants." },
    "/phishingSimulations/{simId}": { "schema": { "$ref": "#/entities/PhishingSimulation" }, "description": "Phishing simulations for tenants." },
    "/reports/{reportId}": { "schema": { "$ref": "#/entities/Report" }, "description": "Generated reports for tenants." },
    "/roles/{roleId}": { "schema": { "$ref": "#/entities/Role" }, "description": "System-wide roles." }
  }
}

    