
{
  "entities": {
    "Tenant": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Tenant",
      "type": "object",
      "description": "Represents a tenant (e.g., a company) using the platform.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the tenant (e.g., 'Acme Corp')."
        },
        "region": {
          "type": "string",
          "description": "The geographical region of the tenant."
        },
        "branding": {
          "type": "object",
          "description": "Custom branding for the tenant."
        }
      },
      "required": ["name", "region"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the platform.",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "tenantId": { "type": "string", "description": "Reference to Tenant." },
        "roleId": { "type": "string", "description": "Reference to Role." },
        "avatarId": { "type": "string", "description": "Reference to a placeholder image ID for the user's avatar." },
        "mfa_enabled": { "type": "boolean", "default": false },
        "status": { "type": "string", "enum": ["Active", "Invited", "Suspended"] },
        "risk": { "type": "string", "enum": ["Low", "Medium", "High"] }
      },
      "required": ["name", "email", "tenantId", "roleId", "status", "risk"]
    },
    "Role": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Role",
      "type": "object",
      "properties": {
        "name": { "type": "string", "enum": ["User", "Admin", "SuperAdmin"] }
      },
      "required": ["name"]
    },
    "Permission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Permission",
      "type": "object",
      "properties": {
        "key": { "type": "string", "description": "e.g. MANAGE_USERS" }
      },
      "required": ["key"]
    },
    "RolePermission": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RolePermission",
      "type": "object",
      "properties": {
        "roleId": { "type": "string" },
        "permissionId": { "type": "string" }
      },
      "required": ["roleId", "permissionId"]
    },
    "Campaign": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Campaign",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "duration": { "type": "string" },
        "audience": { "type": "string" },
        "modules": { 
            "type": "array",
            "items": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "title": { "type": "string" },
                    "description": { "type": "string" }
                },
                "required": ["id", "title", "description"]
            }
        },
        "activities": {
            "type": "array",
            "items": { "type": "string" }
        },
        "kpis": { "type": "string" },
        "type": { "type": "string", "enum": ["training", "phishing", "fraud"] },
        "start_date": { "type": "string", "format": "date-time" },
        "end_date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "active", "completed"] }
      },
      "required": ["title", "status", "type"]
    },
    "Course": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Course",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "duration": { "type": "number", "description": "Duration in minutes." },
        "version": { "type": "string" }
      },
      "required": ["title", "duration"]
    },
    "PhishingSimulation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "PhishingSimulation",
      "type": "object",
      "properties": {
        "template": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["low", "medium", "high"] },
        "scheduled_at": { "type": "string", "format": "date-time" }
      },
      "required": ["template", "difficulty"]
    },
    "FraudScenario": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FraudScenario",
      "type": "object",
      "properties": {
        "scenario_type": { "type": "string" },
        "region": { "type": "string" },
        "risk_level": { "type": "string" }
      },
      "required": ["scenario_type", "region"]
    },
    "Incident": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Incident",
      "type": "object",
      "properties": {
        "reported_by": { "type": "string" },
        "category": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["open", "in_progress", "resolved", "closed"] },
        "assigned_to": { "type": "string" }
      },
      "required": ["reported_by", "category", "severity", "status"]
    },
    "Certification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Certification",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "validity_months": { "type": "number" }
      },
      "required": ["name", "validity_months"]
    },
    "AuditLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AuditLog",
      "type": "object",
      "properties": {
        "actor_id": { "type": "string" },
        "action": { "type": "string" },
        "resource": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["actor_id", "action", "resource", "timestamp"]
    },
    "TrainingModule": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TrainingModule",
      "type": "object",
      "description": "Represents a training module.",
      "properties": {
        "category": { "type": "string" },
        "difficulty": { "type": "string" },
        "aiAdaptive": { "type": "boolean" },
        "duration": { "type": "number" }
      },
      "required": ["category", "difficulty", "aiAdaptive", "duration"]
    },
    "TrainingResult": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "TrainingResult",
      "type": "object",
      "description": "Result of a user completing a training module.",
      "properties": {
        "userId": { "type": "string" },
        "moduleId": { "type": "string" },
        "score": { "type": "number" },
        "timeTaken": { "type": "number" },
        "riskImpact": { "type": "number" }
      },
      "required": ["userId", "moduleId", "score", "timeTaken"]
    },
    "SimulationRequest": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "Simulation Request",
        "type": "object",
        "description": "A request for a cybersecurity simulation submitted by a user.",
        "properties": {
          "userId": { "type": "string", "description": "The ID of the user who submitted the request." },
          "userName": { "type": "string", "description": "The name of the user who submitted the request." },
          "tenantId": { "type": "string", "description": "The ID of the tenant the user belongs to." },
          "simulations": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "description": "The type of simulation requested (e.g., 'Phishing Email Attack')." },
                "details": { "type": "object", "description": "A key-value map of details provided by the user for the simulation." }
              },
              "required": ["type", "details"]
            }
          },
          "status": { "type": "string", "enum": ["Pending", "In Progress", "Completed", "Cancelled"] },
          "requestedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["userId", "userName", "tenantId", "simulations", "status", "requestedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "google.com"]
  },
  "firestore": {
    "/tenants/{tenantId}": {
        "schema": { "$ref": "#/entities/Tenant" },
        "description": "Top-level collection of tenants (corporates)."
    },
    "/tenants/{tenantId}/campaigns/{campaignId}": { "schema": { "$ref": "#/entities/Campaign" }, "description": "Training campaigns specific to a tenant." },
    "/tenants/{tenantId}/courses/{courseId}": { "schema": { "$ref": "#/entities/Course" }, "description": "Courses specific to a tenant." },
    "/tenants/{tenantId}/phishing_simulations/{simId}": { "schema": { "$ref": "#/entities/PhishingSimulation" }, "description": "Phishing simulations for a tenant." },
    "/tenants/{tenantId}/fraud_scenarios/{scenarioId}": { "schema": { "$ref": "#/entities/FraudScenario" }, "description": "Fraud scenarios for a tenant." },
    "/tenants/{tenantId}/incidents/{incidentId}": { "schema": { "$ref": "#/entities/Incident" }, "description": "Security incidents reported within a tenant." },
    "/tenants/{tenantId}/certifications/{certId}": { "schema": { "$ref": "#/entities/Certification" }, "description": "Certifications specific to a tenant." },
    "/tenants/{tenantId}/audit_logs/{logId}": { "schema": { "$ref": "#/entities/AuditLog" }, "description": "Audit logs for actions within a tenant." },
    "/tenants/{tenantId}/simulationRequests/{reqId}": { "schema": { "$ref": "#/entities/SimulationRequest" }, "description": "Simulation requests from users in a tenant." },
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Top-level collection for all users across all tenants."
    },
    "/users/{userId}/trainingResults/{resultId}": { "schema": { "$ref": "#/entities/TrainingResult" }, "description": "Training results for a specific user." },
    "/roles/{roleId}": { "schema": { "$ref": "#/entities/Role" }, "description": "System-wide roles." },
    "/permissions/{permissionId}": { "schema": { "$ref": "#/entities/Permission" }, "description": "System-wide permissions." },
    "/role_permissions/{rpId}": { "schema": { "$ref": "#/entities/RolePermission" }, "description": "Joins roles to permissions." },
    "/trainingModules/{moduleId}": { "schema": { "$ref": "#/entities/TrainingModule" }, "description": "Global library of training modules." }
  }
}
