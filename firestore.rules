
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------
    function requestingUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Get role from roleId stored on user document
    function getRole() {
        let roleId = requestingUserData().roleId;
        // Ensure roleId is not null or empty before trying to access it
        if (roleId != null && roleId != '') {
          return get(/databases/$(database)/documents/roles/$(roleId)).data.name;
        }
        return 'User'; // Default to least privileged role
    }

    function isSuperAdmin() {
      return isSignedIn() && getRole() == 'SuperAdmin';
    }

    function isAdmin() {
      return isSignedIn() && (getRole() == 'Admin' || isSuperAdmin());
    }

    function isTenantAdmin(tenantId) {
      return isAdmin() && requestingUserData().tenantId == tenantId;
    }

    function isMemberOfTenant(tenantId) {
      return isSignedIn() && requestingUserData().tenantId == tenantId;
    }

    function documentExists() {
      return resource != null;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    // SuperAdmins can manage tenants
    match /tenants/{tenantId} {
      allow read: if isMemberOfTenant(tenantId) || isSuperAdmin();
      allow write: if isSuperAdmin();

      // Tenant-specific collections
      // Admins of a tenant can manage sub-collections within their tenant.
      // SuperAdmins have full access.
      match /campaigns/{campaignId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isTenantAdmin(tenantId) || isSuperAdmin();
      }
      match /courses/{courseId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isTenantAdmin(tenantId) || isSuperAdmin();
      }
      match /phishing_simulations/{simId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isTenantAdmin(tenantId) || isSuperAdmin();
      }
       match /fraud_scenarios/{scenarioId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isTenantAdmin(tenantId) || isSuperAdmin();
      }
      match /incidents/{incidentId} {
        allow read: if isMemberOfTenant(tenantId);
        // Any signed-in member of a tenant can create an incident report
        allow create: if isMemberOfTenant(tenantId); 
        allow update, delete: if isTenantAdmin(tenantId) || isSuperAdmin();
      }
      match /certifications/{certId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isTenantAdmin(tenantId) || isSuperAdmin();
      }
      match /audit_logs/{logId} {
        // Audit logs are sensitive and should only be readable by admins of that tenant or super admins
        allow read: if isTenantAdmin(tenantId) || isSuperAdmin();
        // Audit logs should be immutable, only allow create
        allow create: if isSignedIn(); // System/user actions create logs
        allow update, delete: if false;
      }
      match /simulationRequests/{requestId} {
        allow create: if isMemberOfTenant(tenantId) && request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if isTenantAdmin(tenantId) || isSuperAdmin();
      }
    }
    
    // Roles are read-only for authenticated users, writable only by SuperAdmins
    match /roles/{roleId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isSuperAdmin();
    }
    
    // Permissions are managed only by SuperAdmins
    match /permissions/{permissionId} {
        allow read, write: if isSuperAdmin();
    }
    
    // Role-permission mappings are managed only by SuperAdmins
    match /role_permissions/{rolePermissionId} {
        allow read, write: if isSuperAdmin();
    }

    // User management
    match /users/{userId} {
      allow get: if isOwner(userId) || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId) || isSuperAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isTenantAdmin(request.resource.data.tenantId) || isSuperAdmin();
      allow update(writeFields): 
        if isOwner(userId) 
        || (isTenantAdmin(resource.data.tenantId) && !('roleId' in writeFields)) // Tenant admins can't change roles
        || isSuperAdmin();
      allow delete: if documentExists() && (isTenantAdmin(resource.data.tenantId) || isSuperAdmin());

      // User-specific subcollections (e.g., trainingResults)
      match /trainingResults/{trainingResultId} {
        allow read: if isOwner(userId) || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId) || isSuperAdmin();
        allow write: if isOwner(userId);
      }
    }

    // Global training modules are readable by all, writable by admins.
    match /trainingModules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
