
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Check if the requesting user's role name is in a given list.
    function isUserInRole(roleNames) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      let roleDoc = get(/databases/$(database)/documents/roles/$(userDoc.roleId)).data;
      return roleDoc.name in roleNames;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    // SuperAdmins can manage tenants
    match /tenants/{tenantId} {
      allow read: if isUserInRole(['Admin', 'SuperAdmin']) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
      allow write: if isUserInRole(['SuperAdmin']);

      // Tenant-specific collections
      match /campaigns/{campaignId} {
        allow read: if isUserInRole(['Admin', 'SuperAdmin']) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
        allow write: if isUserInRole(['Admin', 'SuperAdmin']);
      }
      match /courses/{courseId} {
        allow read: if isUserInRole(['Admin', 'SuperAdmin']) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
        allow write: if isUserInRole(['Admin', 'SuperAdmin']);
      }
      match /phishing_simulations/{simId} {
        allow read: if isUserInRole(['Admin', 'SuperAdmin']) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
        allow write: if isUserInRole(['Admin', 'SuperAdmin']);
      }
       match /fraud_scenarios/{scenarioId} {
        allow read: if isUserInRole(['Admin', 'SuperAdmin']) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
        allow write: if isUserInRole(['Admin', 'SuperAdmin']);
      }
      match /incidents/{incidentId} {
        allow read: if isUserInRole(['Admin', 'SuperAdmin']) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
        allow create: if isSignedIn(); 
        allow update, delete: if isUserInRole(['Admin', 'SuperAdmin']);
      }
      match /certifications/{certId} {
        allow read: if isUserInRole(['Admin', 'SuperAdmin']) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
        allow write: if isUserInRole(['Admin', 'SuperAdmin']);
      }
      match /audit_logs/{logId} {
        allow read: if isUserInRole(['Admin', 'SuperAdmin']);
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
      match /simulationRequests/{requestId} {
        allow create: if request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if isUserInRole(['Admin', 'SuperAdmin']);
      }
    }
    
    // Roles can be read by any signed-in user, but only listed/written by Admins.
    match /roles/{roleId} {
      allow get: if isSignedIn();
      allow list, write: if isUserInRole(['Admin', 'SuperAdmin']);
    }
    
    // Permissions are managed only by SuperAdmins
    match /permissions/{permissionId} {
        allow read, write: if isUserInRole(['SuperAdmin']);
    }
    
    // Role-permission mappings are managed only by SuperAdmins
    match /role_permissions/{rolePermissionId} {
        allow read, write: if isUserInRole(['SuperAdmin']);
    }

    // User management
    match /users/{userId} {
      // A user can read/write their own document
      allow get, update: if isOwner(userId);

      // Admins can get/update any user document
      allow get, update, delete: if isUserInRole(['Admin', 'SuperAdmin']);
      
      // Anyone can create their own user document on signup
      allow create: if isOwner(userId);
    }
    
    // Admins can list the entire users collection
    match /users {
       allow list: if isUserInRole(['Admin', 'SuperAdmin']);
    }


    // Global training modules are readable by all, writable by admins.
    match /trainingModules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isUserInRole(['Admin', 'SuperAdmin']);
    }
  }
}
