
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ========== HELPER FUNCTIONS ==========

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserRoles() {
      // Safely gets a user's roles array, returning an empty list if not found.
      let doc = get(/databases/$(database)/documents/user_roles/$(request.auth.uid));
      if ('roles' in doc.data) {
        return doc.data.roles;
      }
      return [];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasAnyRole(roles) {
      return isSignedIn() && getUserRoles().hasAny(roles);
    }
    
    function isSuperAdmin() {
      // The primary super admin is hardcoded for initial setup.
      return isSignedIn() && (request.auth.token.email == "wokwemba@safaricom.co.ke" || hasAnyRole(['DOMAIN_ADMIN']));
    }

    function isSecurityAdmin() {
      return isSuperAdmin() || hasAnyRole(['SECURITY_ADMIN']);
    }

    function isTenantAdmin() {
      return isSuperAdmin() || hasAnyRole(['TENANT_ADMIN']);
    }

    function isAuditor() {
      return isSecurityAdmin() || hasAnyRole(['AUDITOR']);
    }
    
    function isPartnerAdmin() {
      return isSuperAdmin() || hasAnyRole(['PARTNER_ADMIN']);
    }
    
    function getMyTenantId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId;
    }


    // ========== GLOBAL COLLECTIONS (Read-only for most users) ==========

    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow write: if isSecurityAdmin();
    }

    match /trainingModules/{moduleId} | /phishing_templates/{templateId} | /subscription_plans/{planId} | /compliance_rules/{ruleId} | /threat_scenarios/{scenarioId} {
      allow read: if isSignedIn();
      allow write: if isSecurityAdmin();
    }
    

    // ========== USER & TENANT MANAGEMENT ==========
    
    match /users/{userId} {
      allow get: if isOwner(userId) || (isTenantAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.tenantId == getMyTenantId());
      allow list: if isTenantAdmin(); // Client query MUST filter by tenantId.
      allow create: if isOwner(userId); // For self-signup. Admin creation is handled by invite flow.
      allow update: if isOwner(userId) || (isTenantAdmin() && resource.data.tenantId == getMyTenantId());
      allow delete: if isSuperAdmin();
    }

    match /user_roles/{userId} {
      allow get: if isOwner(userId) || isSecurityAdmin();
      allow list, create, update: if isSecurityAdmin(); // Only Security Admins should directly manage role mappings.
      allow delete: if false; // Role mappings should not be deleted, only emptied.
    }

    match /tenants/{tenantId} {
      allow get: if isTenantAdmin() && tenantId == getMyTenantId();
      allow list, create, update, delete: if isSuperAdmin();
    }

    match /partner_requests/{requestId} {
      allow read, write: if isPartnerAdmin();
    }

    // ========== AUDITING & LOGS ==========

    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isAuditor();
      allow update, delete: if false;
    }
    
    match /admin_impersonation/{adminId} {
        allow read, write: if isSecurityAdmin();
    }

    // ========== CORE APPLICATION DATA ==========
    
    // This rule specifically handles collections where a user can only list their own documents.
    // The client query is required to filter by userId.
    match /userProgress/{progressId} | /user_challenge_attempts/{attemptId} | /users/{userId}/sms_analyses/{analysisId} {
        // A user can list their own items if they query by their uid.
        allow list: if request.query.userId == request.auth.uid;
        
        // A user can get, create, or update their own record.
        allow get, update: if isOwner(resource.data.userId);
        allow create: if isOwner(request.resource.data.userId);
        
        // Admins can read specific records for support, but not perform broad lists without filters.
        allow get: if isTenantAdmin();
        
        allow delete: if false;
    }
    
    // Tenant-nested collections
    match /tenants/{tenantId}/campaigns/{campaignId} {
      allow read, write: if isTenantAdmin() && tenantId == getMyTenantId();
    }

    // Other collections managed by tenant admins
    match /assignments/{assignmentId} | /phishingSimulations/{simId} | /reports/{reportId} {
      allow read, write: if isTenantAdmin();
    }
    
    match /risk_scores/{userId} {
      allow get: if isOwner(userId) || (isTenantAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.tenantId == getMyTenantId());
      allow list, create, update, delete: if isSecurityAdmin();
    }
  }
}
