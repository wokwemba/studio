
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions based on custom claims
    function isSuperAdmin() {
      return request.auth.token.role == 'super_admin' || request.auth.token.email == 'wokwemba@safaricom.co.ke';
    }

    function isTenantAdmin(tenantId) {
      return request.auth.token.role == 'tenant_admin' && request.auth.token.tenantId == tenantId;
    }

    function isOwnRecord(userId) {
      return request.auth.uid == userId;
    }

    // TENANTS: Only Super Admins can manage tenants. Tenant admins can read their own tenant doc.
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || (isTenantAdmin(tenantId) && isOwnRecord(request.auth.uid));
      allow write: if isSuperAdmin();
    }

    // USERS: Super Admins can manage all users. Tenant Admins can manage users in their tenant.
    // Users can update their own preferences.
    match /users/{userId} {
      allow read: if isSuperAdmin() || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId) || isOwnRecord(userId);
      allow create: if isSuperAdmin() || isTenantAdmin(request.resource.data.tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId) ||
                       (isOwnRecord(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['preferences', 'lastLogin', 'displayName', 'photoURL']));
      allow delete: if isSuperAdmin() || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId);

      // TRAINING RESULTS: Users can read their own training results. Admins can read results for users in their tenant.
      match /trainingResults/{resultId} {
        allow read, write: if isOwnRecord(userId);
        allow read: if isSuperAdmin() || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId);
      }
    }

    // USER PROGRESS: Users can manage their own progress. Admins can view progress within their tenant.
    match /userProgress/{progressId} {
      allow read: if isSuperAdmin() || isTenantAdmin(resource.data.tenantId) || isOwnRecord(resource.data.userId);
      allow create: if isOwnRecord(request.resource.data.userId);
      allow update: if isOwnRecord(resource.data.userId);
      allow delete: if isSuperAdmin() || isOwnRecord(resource.data.userId);
    }
    
    // TRAINING MODULES: Readable by any authenticated user, writable only by Super Admins.
    match /trainingModules/{moduleId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin();
    }
    
    // ASSIGNMENTS: Managed by Tenant Admins and Super Admins.
    match /assignments/{assignmentId} {
        allow read, write: if isSuperAdmin() || isTenantAdmin(resource.data.tenantId);
    }
    
    // PHISHING SIMULATIONS: Managed by Tenant Admins and Super Admins.
    match /phishingSimulations/{simId} {
      allow read, write: if isSuperAdmin() || isTenantAdmin(resource.data.tenantId);
    }
    
    // REPORTS: Managed by Tenant Admins and Super Admins.
    match /reports/{reportId} {
      allow read, write: if isSuperAdmin() || isTenantAdmin(resource.data.tenantId);
    }
    
    // ROLES: Readable by any authenticated user, but only writable by Super Admins.
    match /roles/{roleId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin();
    }

    // SUBSCRIPTION PLANS: Readable by any authenticated user, writable only by Super Admins.
    match /subscription_plans/{planId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin();
    }
  }
}
