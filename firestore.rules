
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =================================
    //     HELPER FUNCTIONS
    // =================================

    // Safely gets the list of role IDs for the currently authenticated user.
    function getUserRoles() {
      let userRolesPath = /databases/$(database)/documents/user_roles/$(request.auth.uid);
      if (exists(userRolesPath)) {
        return get(userRolesPath).data.roles;
      }
      return [];
    }

    // Safely gets the tenant ID of the currently authenticated user.
    function getMyTenantId() {
      let userProfilePath = /databases/$(database)/documents/users/$(request.auth.uid);
      if (exists(userProfilePath) && 'tenantId' in get(userProfilePath).data) {
        return get(userProfilePath).data.tenantId;
      }
      return null;
    }
    
    // Hardcoded check for the primary super admin email for bootstrapping/failsafe.
    function isHardcodedSuperAdmin() {
      return request.auth != null && request.auth.token.email == "wokwemba@safaricom.co.ke";
    }

    // Tier 0: Full system control.
    function isSuperAdmin() {
      return request.auth != null && (isHardcodedSuperAdmin() || getUserRoles().hasAny(['DOMAIN_ADMIN', 'SECURITY_ADMIN']));
    }

    // Tier 2: Manages users and resources within their own tenant.
    function isTenantAdmin() {
      return request.auth != null && getUserRoles().hasAny(['TENANT_ADMIN']);
    }
    
    // Tier 2: Manages partner-related data.
    function isPartnerAdmin() {
      return request.auth != null && getUserRoles().hasAny(['PARTNER_ADMIN']);
    }
    
    // Read-Only: For viewing audit logs.
    function isAuditor() {
      return request.auth != null && getUserRoles().hasAny(['AUDITOR']);
    }

    // Checks if the requesting user is the owner of the document.
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // =================================
    //     COLLECTION RULES
    // =================================

    // --- User and Role Management ---

    match /users/{userId} {
      allow get: if isOwner(userId)
                   || isSuperAdmin()
                   || (isTenantAdmin() && resource.data.tenantId == getMyTenantId());
      allow list: if isSuperAdmin() 
                    || (isTenantAdmin() && request.query.tenantId == getMyTenantId());
      allow create: if request.auth != null; // Any authenticated user can sign up, admins can create.
      allow update: if isOwner(userId)
                      || isSuperAdmin()
                      || (isTenantAdmin() && resource.data.tenantId == getMyTenantId());
      allow delete: if isSuperAdmin();
    }

    match /user_roles/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin() || isTenantAdmin();
      allow list: if isSuperAdmin() || isTenantAdmin();
      // Only Super Admins can change roles to prevent privilege escalation.
      allow create, update, delete: if isSuperAdmin();
    }
    
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin(); // Only Super Admins can define what roles exist.
    }

    // --- Admin & Tenant Management ---

    match /tenants/{tenantId} {
      allow get: if isSuperAdmin() || (isTenantAdmin() && getMyTenantId() == tenantId);
      allow list, create, update, delete: if isSuperAdmin();
    }
    
    match /partner_requests/{requestId} {
      allow read, write: if isSuperAdmin() || isPartnerAdmin();
    }
    
    // Tenant-specific subcollections
    match /tenants/{tenantId}/{subcollection}/{docId} {
       allow read, write: if isSuperAdmin() || (isTenantAdmin() && getMyTenantId() == tenantId);
    }
    
    // --- User-Specific Content (Progress, Attempts, etc.) ---
    
    match /userProgress/{progressId} {
      // A user can ONLY read their OWN progress documents.
      // This simplified rule ensures client-side queries for a user's own data are always allowed and performant.
      allow read: if request.auth.uid == resource.data.userId;
      
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false; // Deletes are not allowed from the client.
    }
    
    match /user_challenge_attempts/{attemptId} {
      // A user can ONLY read their OWN attempts.
      allow read: if request.auth.uid == resource.data.userId;

      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    
    match /users/{userId}/sms_analyses/{analysisId} {
        allow read, create, list: if isOwner(userId);
        allow update, delete: if false;
    }

    // --- Global Content & Configuration ---

    match /trainingModules/{moduleId}      { allow read: if request.auth != null; allow write: if isSuperAdmin(); }
    match /phishing_templates/{templateId} { allow read: if request.auth != null; allow write: if isSuperAdmin(); }
    match /subscription_plans/{planId}     { allow read: if request.auth != null; allow write: if isSuperAdmin(); }
    match /compliance_rules/{ruleId}       { allow read: if request.auth != null; allow write: if isSuperAdmin(); }
    match /threat_scenarios/{scenarioId}   { allow read: if request.auth != null; allow write: if isSuperAdmin(); }

    // --- System & Audit Collections ---

    match /audit_logs/{logId} {
      allow create: if request.auth != null; // System actions can create logs.
      allow read: if isAuditor() || isSuperAdmin();
      allow update, delete: if false; // Logs are immutable.
    }

    match /risk_scores/{userId} {
      allow get: if isOwner(userId) || isTenantAdmin() || isSuperAdmin();
      allow list, create, update, delete: if isSuperAdmin(); // Risk calculation is a backend/admin process.
    }
    
    match /admin_impersonation/{adminId} {
        allow read, write: if isSuperAdmin();
    }
  }
}
