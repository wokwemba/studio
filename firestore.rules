
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin(userId) {
      return get(/databases/$(database)/documents/user_roles/$(userId)).data.roles.hasAny(['L1A4b6Y2y1l9p3R0c2V1']);
    }

    function isAdmin(userId) {
        return get(/databases/$(database)/documents/user_roles/$(userId)).data.roles.hasAny(['L1A4b6Y2y1l9p3R0c2V1', 'S2V1b2l1R1dsa2FqZGZtYWxza2Rq']);
    }
    
    function isTenantAdmin(userId, tenantId) {
        let userDoc = get(/databases/$(database)/documents/users/$(userId)).data;
        return userDoc.tenantId == tenantId && get(/databases/$(database)/documents/user_roles/$(userId)).data.roles.hasAny(['T3N4bW50QWRtaW5VaiBva21hbA']);
    }

    function isOwnRecord(userId) {
      return request.auth.uid == userId;
    }
    
    // PARTNER REQUESTS: Allow anyone to submit a partnership request.
    match /partner_requests/{requestId} {
      allow create: if true;
      // Reading/writing should be restricted to super admins
      allow read, update, delete: if isSuperAdmin(request.auth.uid);
    }

    // TENANTS: Only Super Admins can manage tenants. Tenant admins can read their own tenant doc.
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, tenantId);
      allow write: if isSuperAdmin(request.auth.uid);

      // CAMPAIGNS: Managed by Tenant Admins and Super Admins for their own tenant.
      match /campaigns/{campaignId} {
        allow read, write: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, tenantId);
      }

      // SIMULATION REQUESTS
      match /simulationRequests/{requestId} {
        allow create: if isOwnRecord(request.resource.data.userId);
        allow read, update, delete: if isTenantAdmin(request.auth.uid, tenantId) || isSuperAdmin(request.auth.uid);
      }
    }

    // USERS:
    match /users/{userId} {
      allow get: if isOwnRecord(userId) || isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, get(/databases/$(database)/documents/users/$(userId)).data.tenantId);
      allow list: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId);
      
      allow create: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, request.resource.data.tenantId);
      
      allow update: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, get(/databases/$(database)/documents/users/$(userId)).data.tenantId) ||
                       (isOwnRecord(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['preferences', 'lastLogin', 'displayName', 'photoURL', 'department', 'risk']));

      allow delete: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, get(/databases/$(database)/documents/users/$(userId)).data.tenantId);

      // SMS ANALYSIS: Users can manage their own analysis results.
      match /sms_analyses/{analysisId} {
        allow read, write: if isOwnRecord(userId);
      }

      // TRAINING RESULTS: Users can manage their own results.
      match /trainingResults/{resultId} {
        allow create: if isOwnRecord(userId);
        allow read: if isOwnRecord(userId) || isTenantAdmin(request.auth.uid, get(/databases/$(database)/documents/users/$(userId)).data.tenantId) || isSuperAdmin(request.auth.uid);
        allow update, delete: if isOwnRecord(userId);
      }
    }

    // USER PROGRESS: Users can manage their own progress. Admins can view progress within their tenant.
    match /userProgress/{progressId} {
      allow read: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, resource.data.tenantId) || isOwnRecord(resource.data.userId);
      allow create: if isOwnRecord(request.resource.data.userId);
      allow update: if isOwnRecord(resource.data.userId);
      allow delete: if isSuperAdmin(request.auth.uid) || isOwnRecord(resource.data.userId);
    }
    
    // USER CHALLENGE ATTEMPTS: Users can create their own attempts. Admins can view attempts within their tenant.
    match /user_challenge_attempts/{attemptId} {
      allow create: if isOwnRecord(request.resource.data.userId);
      allow read: if isOwnRecord(resource.data.userId) || isTenantAdmin(request.auth.uid, resource.data.tenantId) || isSuperAdmin(request.auth.uid);
      allow update, delete: if false;
    }

    // TRAINING MODULES: Readable by any authenticated user, writable only by Super Admins.
    match /trainingModules/{moduleId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin(request.auth.uid);
    }
    
    // ASSIGNMENTS: Managed by Tenant Admins and Super Admins.
    match /assignments/{assignmentId} {
        allow read, write: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, resource.data.tenantId);
    }
    
    // PHISHING SIMULATIONS: Managed by Tenant Admins and Super Admins.
    match /phishingSimulations/{simId} {
      allow read, write: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, resource.data.tenantId);
    }
    
    // PHISHING TEMPLATES: Writable by Super Admins, readable by all admins.
    match /phishing_templates/{templateId} {
      allow read: if isSuperAdmin(request.auth.uid) || isAdmin(request.auth.uid);
      allow write: if isSuperAdmin(request.auth.uid);
    }
    
    // REPORTS: Managed by Tenant Admins and Super Admins.
    match /reports/{reportId} {
      allow read, write: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, resource.data.tenantId);
    }
    
    // ROLES: Readable by any authenticated user, but only writable by Super Admins.
    match /roles/{roleId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin(request.auth.uid);
    }

    // USER ROLES: Super Admins can write. Authenticated users can read their own roles.
    match /user_roles/{userId} {
      allow read: if isOwnRecord(userId) || isSuperAdmin(request.auth.uid);
      allow write: if isSuperAdmin(request.auth.uid);
    }

    // SUBSCRIPTION PLANS: Readable by any authenticated user, writable only by Super Admins.
    match /subscription_plans/{planId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin(request.auth.uid);
    }

    // COMPLIANCE RULES: Readable by any authenticated user, writable only by Super Admins.
    match /compliance_rules/{ruleId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin(request.auth.uid);
    }

    // RISK SCORES: Writable by admins, readable by the user and their admins.
    match /risk_scores/{userId} {
      allow read: if isOwnRecord(userId) || isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, resource.data.tenantId);
      allow write: if isSuperAdmin(request.auth.uid) || isTenantAdmin(request.auth.uid, request.resource.data.tenantId);
    }

    // AUDIT LOGS: Only allow creation by authenticated users and reading by Super Admins.
    match /audit_logs/{logId} {
      allow create: if request.auth.uid != null;
      allow read: if isSuperAdmin(request.auth.uid);
      allow update, delete: if false;
    }

    // ADMIN IMPERSONATION: Only the admin themselves can read/write their own session.
    match /admin_impersonation/{adminId} {
      allow read, write: if isSuperAdmin(request.auth.uid) && isOwnRecord(adminId);
    }

    // THREAT SCENARIOS: Readable by authenticated users, writable by Super Admins.
    match /threat_scenarios/{scenarioId} {
        allow get, list: if request.auth.uid != null;
        allow write: if isSuperAdmin(request.auth.uid);
    }
  }
}
