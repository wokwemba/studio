rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User documents
    match /users/{userId} {
      // Regular user: only their own doc
      allow read, write: if request.auth.uid == userId;

      // Admin: any user doc
      allow read, write: if request.auth.token.admin == true;
    }

    // Entire users collection
    match /users/{document=**} {
      // Only admins can list all users
      allow list: if request.auth.token.admin == true;
    }

    // Roles collection
    match /roles/{roleId} {
      // Admins can read/write roles
      allow read, write: if request.auth.token.admin == true;
    }

    match /roles/{document=**} {
      // Only admins can list all roles
      allow list: if request.auth.token.admin == true;
    }
    
    // Tenant-specific data
    match /tenants/{tenantId} {
      // Admins and users belonging to the tenant can read tenant data.
      allow read: if request.auth.token.admin == true || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
      // Only admins (or a future SuperAdmin role) can write to tenants.
      allow write: if request.auth.token.admin == true;

      // Subcollections within a tenant
      match /campaigns/{campaignId} {
        allow read, write: if request.auth.token.admin == true;
      }
      match /courses/{courseId} {
        allow read, write: if request.auth.token.admin == true;
      }
      match /phishing_simulations/{simId} {
        allow read, write: if request.auth.token.admin == true;
      }
       match /fraud_scenarios/{scenarioId} {
        allow read, write: if request.auth.token.admin == true;
      }
      match /incidents/{incidentId} {
        allow read: if request.auth.token.admin == true;
        allow create: if request.auth.uid != null; 
        allow update, delete: if request.auth.token.admin == true;
      }
      match /certifications/{certId} {
        allow read, write: if request.auth.token.admin == true;
      }
      match /audit_logs/{logId} {
        allow read: if request.auth.token.admin == true;
        allow create: if request.auth.uid != null;
        allow update, delete: if false;
      }
      match /simulationRequests/{requestId} {
        allow create: if request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if request.auth.token.admin == true;
      }
    }

    // Training Modules are readable by any authenticated user, but only writable by admins.
    match /trainingModules/{moduleId} {
      allow read: if request.auth.uid != null;
      allow write: if request.auth.token.admin == true;
    }
  }
}
