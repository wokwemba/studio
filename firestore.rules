
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions based on custom claims
    function isSuperAdmin() {
      return request.auth.token.role == 'SuperAdmin' || request.auth.token.email == 'wokwemba@safaricom.co.ke';
    }

    function isTenantAdmin(tenantId) {
      return request.auth.token.role == 'Admin' && request.auth.token.tenantId == tenantId;
    }

    function isOwnRecord(userId) {
      return request.auth.uid == userId;
    }
    
    // PARTNER REQUESTS: Allow anyone to submit a partnership request.
    match /partner_requests/{requestId} {
      allow create: if true;
      // Reading/writing should be restricted to admins
      allow read, update, delete: if isSuperAdmin();
    }

    // TENANTS: Only Super Admins can manage tenants. Tenant admins can read their own tenant doc.
    match /tenants/{tenantId} {
      allow read: if isSuperAdmin() || (isTenantAdmin(tenantId) && isOwnRecord(request.auth.uid));
      allow write: if isSuperAdmin();
    }

    // USERS: Super Admins can manage all users. Tenant Admins can manage users in their tenant.
    // Users can update their own preferences.
    match /users/{userId} {
      allow read: if isSuperAdmin() || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId) || isOwnRecord(userId);
      allow create: if isOwnRecord(userId) || isSuperAdmin() || isTenantAdmin(request.resource.data.tenantId);
      allow update: if isSuperAdmin() || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId) ||
                       (isOwnRecord(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['preferences', 'lastLogin', 'displayName', 'photoURL', 'risk', 'assignedTenants']));
      allow delete: if isSuperAdmin() || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId) || (resource.data.status == 'Invited' && resource.data.email == request.auth.token.email);

      // TRAINING RESULTS: Users can read their own training results. Admins can read results for users in their tenant.
      match /trainingResults/{resultId} {
        allow read, write: if isOwnRecord(userId);
        allow read: if isSuperAdmin() || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId);
      }

      // SMS ANALYSIS: Users can manage their own analysis results.
      match /sms_analyses/{analysisId} {
        allow read: if isOwnRecord(userId);
        allow write: if isOwnRecord(userId);
      }
    }

    // USER PROGRESS: Users can manage their own progress. Admins can view progress within their tenant.
    match /userProgress/{progressId} {
      allow read: if isSuperAdmin() || isTenantAdmin(resource.data.tenantId) || isOwnRecord(resource.data.userId);
      allow create: if isOwnRecord(request.resource.data.userId);
      allow update: if isOwnRecord(resource.data.userId);
      allow delete: if isSuperAdmin() || isOwnRecord(resource.data.userId);
    }
    
    // TRAINING MODULES: Readable by any authenticated user, writable only by Super Admins.
    match /trainingModules/{moduleId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin();
    }
    
    // ASSIGNMENTS: Managed by Tenant Admins and Super Admins.
    match /assignments/{assignmentId} {
        allow read, write: if isSuperAdmin() || isTenantAdmin(resource.data.tenantId);
    }
    
    // PHISHING SIMULATIONS: Managed by Tenant Admins and Super Admins.
    match /phishingSimulations/{simId} {
      allow read, write: if isSuperAdmin() || isTenantAdmin(resource.data.tenantId);
    }
    
    // PHISHING TEMPLATES: Writable by Super Admins, readable by all admins.
    match /phishing_templates/{templateId} {
      allow read: if isSuperAdmin() || request.auth.token.role == 'tenant_admin';
      allow write: if isSuperAdmin();
    }
    
    // REPORTS: Managed by Tenant Admins and Super Admins.
    match /reports/{reportId} {
      allow read, write: if isSuperAdmin() || isTenantAdmin(resource.data.tenantId);
    }
    
    // ROLES: Readable by any authenticated user, but only writable by Super Admins.
    match /roles/{roleId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin();
    }

    // SUBSCRIPTION PLANS: Readable by any authenticated user, writable only by Super Admins.
    match /subscription_plans/{planId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin();
    }

    // COMPLIANCE RULES: Readable by any authenticated user, writable only by Super Admins.
    match /compliance_rules/{ruleId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin();
    }

    // RISK SCORES: Writable by admins, readable by the user and their admins.
    match /risk_scores/{userId} {
      allow read: if isOwnRecord(userId) || isSuperAdmin() || isTenantAdmin(resource.data.tenantId);
      allow write: if isSuperAdmin() || isTenantAdmin(request.resource.data.tenantId);
    }

    // AUDIT LOGS: Only allow creation by authenticated users and reading by Super Admins.
    match /audit_logs/{logId} {
      allow create: if request.auth.uid != null;
      allow read: if isSuperAdmin();
      allow update, delete: if false;
    }

    // ADMIN IMPERSONATION: Only the admin themselves can read/write their own session.
    match /admin_impersonation/{adminId} {
      allow read, write: if request.auth.uid == adminId;
    }
  }
}
