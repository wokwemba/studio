
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Safe helper: return roles array or empty array
    function getUserRoles() {
      let path = /databases/$(database)/documents/user_roles/$(request.auth.uid);
      return exists(path) && ('roles' in get(path).data) && get(path).data.roles is list
             ? get(path).data.roles
             : [];
    }

    // Hardcoded super admin email (always treated as super admin)
    function isHardcodedSuperAdmin() {
      return request.auth != null
             && request.auth.token.email == "wokwemba@safaricom.co.ke";
    }

    function isSuperAdmin() {
      return request.auth != null && (isHardcodedSuperAdmin() || getUserRoles().hasAny(['DOMAIN_ADMIN']));
    }

    function isSecurityAdmin() {
      return request.auth != null && (isHardcodedSuperAdmin() || getUserRoles().hasAny(['SECURITY_ADMIN']));
    }

    function isTenantAdmin() {
      return request.auth != null && (isSuperAdmin() || getUserRoles().hasAny(['TENANT_ADMIN']));
    }

    function isAuditor() {
      return request.auth != null && getUserRoles().hasAny(['AUDITOR']);
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Safe tenant check: returns null if either doc missing
    function getMyTenantId() {
      let myPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(myPath) && ('tenantId' in get(myPath).data) ? get(myPath).data.tenantId : null;
    }

    function isUserInTenant(userId) {
      let userPath = /databases/$(database)/documents/users/$(userId);
      if (!exists(userPath)) { return false; }
      let userTenant = get(userPath).data.tenantId;
      let myTenant = getMyTenantId();
      return myTenant != null && userTenant == myTenant;
    }

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isOwner(userId)
                  || (isTenantAdmin() && isUserInTenant(userId))
                  || isSuperAdmin()
                  || isSecurityAdmin();

      allow list: if isSuperAdmin()
                   || isSecurityAdmin()
                   || (isTenantAdmin() && getMyTenantId() != null
                       && request.query.where('tenantId', '==', getMyTenantId()));

      allow create: if (request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.tenantId is string
                    && request.resource.data.displayName is string
                    && request.resource.data.keys().hasOnly(['email','displayName','tenantId','status','risk','photoURL','avatarId','createdAt'])
                    && request.resource.data.createdAt is timestamp)
                  || isSuperAdmin()
                  || isSecurityAdmin();

      allow update: if (isOwner(userId)
                    && request.resource.data.keys().hasOnly(resource.data.keys()))
                    || isSuperAdmin()
                    || isSecurityAdmin();

      allow delete: if isSuperAdmin() || isSecurityAdmin();
    }

    // USER_ROLES COLLECTION
    match /user_roles/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin() || isSecurityAdmin();
      allow list: if isSuperAdmin() || isSecurityAdmin();
      allow create, update, delete: if isSuperAdmin() || isSecurityAdmin();
    }

    // ROLES COLLECTION
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin() || isSecurityAdmin();
    }

    // AUDIT LOGS
    match /audit_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if isSuperAdmin() || isSecurityAdmin() || isAuditor();
      allow update, delete: if false;
    }

    // Fallback for other collections
    match /{path=**} {
        allow read, write: if isSuperAdmin();
    }
  }
}
