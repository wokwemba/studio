rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------
    function requestingUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // Get role from roleId stored on user document
    function getRole() {
        return get(/databases/$(database)/documents/roles/$(requestingUserData().roleId)).data.name;
    }

    function isSuperAdmin() {
      return isSignedIn() && getRole() == 'SuperAdmin';
    }

    function isAdmin() {
      return isSignedIn() && (getRole() == 'Admin' || isSuperAdmin());
    }

    function isTenantAdmin(tenantId) {
      return isAdmin() && requestingUserData().tenantId == tenantId;
    }

    function isMemberOfTenant(tenantId) {
      return isSignedIn() && requestingUserData().tenantId == tenantId;
    }

    function documentExists() {
      return resource != null;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    // SuperAdmins can manage tenants
    match /tenants/{tenantId} {
      allow read: if isMemberOfTenant(tenantId) || isSuperAdmin();
      allow write: if isSuperAdmin();

      // Tenant-specific collections
      match /{subCollection}/{docId} {
        allow read: if isMemberOfTenant(tenantId) || isSuperAdmin();
        allow write: if isTenantAdmin(tenantId) || isSuperAdmin();
      }
    }
    
    // Roles are read-only for authenticated users, writable only by SuperAdmins
    match /roles/{roleId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow write: if isSuperAdmin();
    }
    
    // Permissions are managed by SuperAdmins
    match /permissions/{permissionId} {
        allow read, write: if isSuperAdmin();
    }
    
    // Role-permission mappings are managed by SuperAdmins
    match /role_permissions/{rolePermissionId} {
        allow read, write: if isSuperAdmin();
    }

    // User management
    match /users/{userId} {
      // Users can read/update their own profile.
      // Admins can read profiles in their tenant.
      // SuperAdmins have full access.
      allow get: if isOwner(userId) || isTenantAdmin(resource.data.tenantId) || isSuperAdmin();
      allow list: if isAdmin(); // Admins can list users in their tenant, SuperAdmins can list all.
      allow create: if isOwner(userId) || isTenantAdmin(request.resource.data.tenantId) || isSuperAdmin();
      allow update: if documentExists() && (isOwner(userId) || isTenantAdmin(resource.data.tenantId) || isSuperAdmin());
      allow delete: if documentExists() && (isOwner(userId) || isSuperAdmin());

      // User-specific subcollections (e.g., trainingResults)
      match /trainingResults/{trainingResultId} {
        allow read: if isOwner(userId) || isTenantAdmin(get(/databases/$(database)/documents/users/$(userId)).data.tenantId) || isSuperAdmin();
        allow write: if isOwner(userId);
      }
    }

    // Global training modules are readable by all, writable by admins.
    match /trainingModules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
