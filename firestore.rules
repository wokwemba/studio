
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------
    function requestingUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isSuperAdmin() {
      return request.auth.token.superadmin == true;
    }

    function isAdmin() {
      return request.auth.token.admin == true || isSuperAdmin();
    }

    function isTenantAdmin(tenantId) {
      // This function may need re-evaluation in a custom claims model
      // For now, it assumes an admin of a tenant has the 'admin' claim and matches tenantId
      return isAdmin() && requestingUserData().tenantId == tenantId;
    }

    function isMemberOfTenant(tenantId) {
      return isSignedIn() && requestingUserData().tenantId == tenantId;
    }

    function documentExists() {
      return resource != null;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------

    // SuperAdmins can manage tenants
    match /tenants/{tenantId} {
      allow read: if isMemberOfTenant(tenantId) || isSuperAdmin();
      allow write: if isSuperAdmin();

      // Tenant-specific collections
      match /campaigns/{campaignId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isAdmin();
      }
      match /courses/{courseId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isAdmin();
      }
      match /phishing_simulations/{simId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isAdmin();
      }
       match /fraud_scenarios/{scenarioId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isAdmin();
      }
      match /incidents/{incidentId} {
        allow read: if isMemberOfTenant(tenantId);
        allow create: if isMemberOfTenant(tenantId); 
        allow update, delete: if isAdmin();
      }
      match /certifications/{certId} {
        allow read: if isMemberOfTenant(tenantId);
        allow write: if isAdmin();
      }
      match /audit_logs/{logId} {
        allow read: if isAdmin();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
      match /simulationRequests/{requestId} {
        allow create: if isMemberOfTenant(tenantId) && request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if isAdmin();
      }
    }
    
    // Roles are read-only for authenticated users, writable only by SuperAdmins
    match /roles/{roleId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if isSuperAdmin();
    }
    
    // Permissions are managed only by SuperAdmins
    match /permissions/{permissionId} {
        allow read, write: if isSuperAdmin();
    }
    
    // Role-permission mappings are managed only by SuperAdmins
    match /role_permissions/{rolePermissionId} {
        allow read, write: if isSuperAdmin();
    }

    // User management
    match /users/{userId} {
      // A user can read/write their own document
      allow get, update: if isOwner(userId);

      // Admins can get/update any user document
      allow get, update, delete: if isAdmin();
      
      // Anyone can create their own user document on signup
      allow create: if isOwner(userId);
    }

    // Admins can list the entire users collection
    match /users {
       allow list: if isAdmin();
    }

    // Global training modules are readable by all, writable by admins.
    match /trainingModules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
