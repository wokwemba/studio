rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth.token.admin == true;
    }

    // ------------------------------------------------------------------------
    // Collection Rules
    // ------------------------------------------------------------------------
    
    // Rule for individual user documents
    match /users/{userId} {
      // A user can read/write their own document
      allow read, write: if isOwner(userId);
      
      // Admins can read/write any user document
      allow read, write: if isAdmin();
    }

    // Rule for listing the entire users collection
    match /users/{document=**} {
      // Only admins can list all users
      allow list: if isAdmin();
    }

    // Roles collection
    match /roles/{roleId} {
      // Admins can read/write roles
      allow read, write: if isAdmin();
    }

    match /roles/{document=**} {
      // Only admins can list all roles
      allow list: if isAdmin();
    }
    
    // Tenant-specific data
    match /tenants/{tenantId} {
      // Admins and users belonging to the tenant can read tenant data.
      allow read: if isAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
      // Only admins (or a future SuperAdmin role) can write to tenants.
      allow write: if isAdmin();

      // Subcollections within a tenant
      match /campaigns/{campaignId} {
        allow read, write: if isAdmin();
      }
      match /courses/{courseId} {
        allow read, write: if isAdmin();
      }
      match /phishing_simulations/{simId} {
        allow read, write: if isAdmin();
      }
       match /fraud_scenarios/{scenarioId} {
        allow read, write: if isAdmin();
      }
      match /incidents/{incidentId} {
        allow read: if isAdmin();
        allow create: if isSignedIn(); 
        allow update, delete: if isAdmin();
      }
      match /certifications/{certId} {
        allow read, write: if isAdmin();
      }
      match /audit_logs/{logId} {
        allow read: if isAdmin();
        allow create: if isSignedIn();
        allow update, delete: if false;
      }
      match /simulationRequests/{requestId} {
        allow create: if request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if isAdmin();
      }
    }

    // Training Modules are readable by any authenticated user, but only writable by admins.
    match /trainingModules/{moduleId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
