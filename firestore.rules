
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Safely get user roles; return empty array if document doesn't exist
    function getUserRoles() {
      let path = /databases/$(database)/documents/user_roles/$(request.auth.uid);
      // Ensure the document exists AND the 'roles' field is a list before returning.
      if (exists(path)) {
        let data = get(path).data;
        if ('roles' in data && data.roles is list) {
          return data.roles;
        }
      }
      return [];
    }
    
    // Helper to get the requesting admin's tenantId safely
    function getAdminTenantId() {
        let adminPath = /databases/$(database)/documents/users/$(request.auth.uid);
        if (exists(adminPath) && 'tenantId' in get(adminPath).data) {
            return get(adminPath).data.tenantId;
        }
        return null;
    }

    // Tier 0 - Highest Privilege
    function isSuperAdmin() {
      return getUserRoles().hasAny(['DOMAIN_ADMIN', 'SECURITY_ADMIN']);
    }
    
    // Tier 1 - Platform & Engineering
    function isTier1Admin() {
      return isSuperAdmin() || getUserRoles().hasAny(['PLATFORM_ADMIN', 'DEVOPS_ENGINEER', 'APPLICATION_DEVELOPER']);
    }
    
    // Tier 2 - Tenant & Business Management
    function isTenantAdmin() {
      return isTier1Admin() || getUserRoles().hasAny(['TENANT_ADMIN', 'PARTNER_ADMIN', 'SUPPORT_ADMIN']);
    }
    
    function isAuditor() {
      return getUserRoles().hasAny(['AUDITOR']);
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // USERS & ROLES
    match /users/{userId} {
      allow get: if isOwner(userId) || (isTenantAdmin() && getAdminTenantId() != null && resource.data.tenantId == getAdminTenantId());
      
      // Allow Admins to list users ONLY within their own tenant
      allow list: if isSuperAdmin() || (isTenantAdmin() && getAdminTenantId() != null && request.query.where('tenantId', '==', getAdminTenantId()));
      
      allow update: if isOwner(userId) || isSuperAdmin();
      
      // A user can create their own profile, or a Super Admin can create one.
      allow create: if isOwner(userId) || isSuperAdmin();
      
      allow delete: if isSuperAdmin();
    }

    match /user_roles/{userId} {
      allow get: if isOwner(userId) || isSuperAdmin();
      // A user can create their own role document upon signup.
      allow create: if isOwner(userId) || isSuperAdmin();
      // Only Super Admins can list all roles or modify them later.
      allow list, update, delete: if isSuperAdmin();
    }
    
    match /roles/{roleId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    // AUDIT & IMPERSONATION LOGS
    match /audit_logs/{logId} {
      allow create: if request.auth.uid != null;
      allow read: if isSuperAdmin() || isAuditor();
      allow update, delete: if false;
    }

    match /admin_impersonation/{adminId} {
      allow read, write: if isSuperAdmin() && isOwner(adminId);
    }
    
    // PARTNERS & TENANTS
    match /partner_requests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isTenantAdmin();
    }

    match /tenants/{tenantId} {
      allow read, write: if isTenantAdmin();

      match /campaigns/{campaignId} {
        allow read, write: if isTenantAdmin();
      }
      match /simulationRequests/{requestId} {
        allow create: if request.resource.data.userId == request.auth.uid;
        allow read, update, delete: if isTenantAdmin();
      }
    }
    
    // TRAINING & CONTENT
    match /trainingModules/{moduleId} {
      allow read: if request.auth.uid != null;
      allow write: if isTier1Admin();
    }
    
    match /threat_scenarios/{scenarioId} {
        allow get, list: if request.auth.uid != null;
        allow write: if isTier1Admin();
    }
    
    // USER-SPECIFIC DATA
    match /userProgress/{progressId} {
      allow read: if isOwner(resource.data.userId) || (isTenantAdmin() && getAdminTenantId() != null && resource.data.tenantId == getAdminTenantId());
      allow create, update: if isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    match /user_challenge_attempts/{attemptId} {
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || (isTenantAdmin() && getAdminTenantId() != null && resource.data.tenantId == getAdminTenantId());
      allow update, delete: if false; // Attempts are immutable
    }

    match /users/{userId}/sms_analyses/{analysisId} {
      allow read, write: if isOwner(userId);
    }
    
    // OTHER COLLECTIONS
    match /phishing_templates/{templateId} {
      allow read: if isTenantAdmin();
      allow write: if isTier1Admin();
    }
    
    match /phishingSimulations/{simId} {
        allow read, write: if isTenantAdmin();
    }

    match /assignments/{assignmentId} {
        allow read, write: if isTenantAdmin();
    }
    
    match /reports/{reportId} {
      allow read, write: if isTenantAdmin();
    }

    match /subscription_plans/{planId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin();
    }

    match /compliance_rules/{ruleId} {
      allow read: if request.auth.uid != null;
      allow write: if isSuperAdmin();
    }
    
    match /risk_scores/{userId} {
      allow read: if isOwner(userId) || isTenantAdmin();
      allow write: if isTenantAdmin();
    }
  }
}
