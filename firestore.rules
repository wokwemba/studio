
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserRoles() {
      // Helper to securely get the roles array for the requesting user.
      return get(/databases/$(database)/documents/user_roles/$(request.auth.uid)).data.roles;
    }
    
    // Tier 0 - Highest Privilege
    function isTier0() {
      return getUserRoles().hasAny(['DOMAIN_ADMIN', 'SECURITY_ADMIN']);
    }
    
    // Tier 1 - Platform & Engineering
    function isTier1() {
      return isTier0() || getUserRoles().hasAny(['PLATFORM_ADMIN', 'DEVOPS_ENGINEER', 'APPLICATION_DEVELOPER']);
    }
    
    // Tier 2 - Tenant & Business Management
    function isTier2() {
      return isTier1() || getUserRoles().hasAny(['TENANT_ADMIN', 'PARTNER_ADMIN', 'SUPPORT_ADMIN']);
    }
    
    function isAuditor() {
        return getUserRoles().hasAny(['AUDITOR']);
    }

    // USERS & ROLES
    match /users/{userId} {
      // Any authenticated user can get their own profile. Tier 0 can get any profile.
      allow get: if isOwner(userId) || isTier0();
      // Only Tier 0 can list all users.
      allow list: if isTier0();
      // Users can update their own profile. Tier 0 can update any profile.
      allow update: if isOwner(userId) || isTier0();
      // Only Tier 0 can create or delete users.
      allow create, delete: if isTier0();
    }

    match /user_roles/{userId} {
      // Users can read their own roles. Tier 0 can read any.
      allow get: if isOwner(userId) || isTier0();
      // Only Tier 0 can list or modify role assignments.
      allow list, write: if isTier0();
    }
    
    match /roles/{roleId} {
      // All authenticated users can read role definitions.
      allow read: if request.auth != null;
      // Only Tier 0 can create or modify roles.
      allow write: if isTier0();
    }

    // AUDIT & IMPERSONATION LOGS
    match /audit_logs/{logId} {
      // Any authenticated user can trigger an auditable event.
      allow create: if request.auth.uid != null;
      // Only Tier 0 and Auditors can read audit logs.
      allow read: if isTier0() || isAuditor();
      // Logs are immutable.
      allow update, delete: if false;
    }

    match /admin_impersonation/{adminId} {
      // Only a Tier 0 admin can manage their own impersonation session.
      allow read, write: if isTier0() && isOwner(adminId);
    }
    
    // PARTNERS & TENANTS
    match /partner_requests/{requestId} {
      // Anyone can submit a partnership request.
      allow create: if true;
      // Tier 2 and above can manage requests.
      allow read, update, delete: if isTier2();
    }

    match /tenants/{tenantId} {
      // Tier 2 and above can manage tenants.
      allow read, write: if isTier2();

      // Campaigns and Simulation requests are nested under tenants.
      match /campaigns/{campaignId} {
        allow read, write: if isTier2();
      }
      match /simulationRequests/{requestId} {
        allow create: if isOwner(request.resource.data.userId);
        allow read, update, delete: if isTier2();
      }
    }
    
    // TRAINING & CONTENT
    match /trainingModules/{moduleId} {
      // Any authenticated user can read content.
      allow read: if request.auth.uid != null;
      // Tier 1 and above can write content.
      allow write: if isTier1();
    }
    
    match /threat_scenarios/{scenarioId} {
        // Any authenticated user can read scenarios.
        allow get, list: if request.auth.uid != null;
        // Tier 1 and above can write scenarios.
        allow write: if isTier1();
    }
    
    // USER-SPECIFIC DATA
    match /userProgress/{progressId} {
        // Users can manage their own progress. Tier 2 admins can view progress within their tenant (future-proofing).
      allow read: if isOwner(resource.data.userId) || isTier2();
      allow create, update: if isOwner(request.resource.data.userId);
      allow delete: if isOwner(resource.data.userId);
    }
    
    match /user_challenge_attempts/{attemptId} {
        // Users can create their own attempts. Tier 2 admins can view attempts within their tenant.
      allow create: if isOwner(request.resource.data.userId);
      allow read: if isOwner(resource.data.userId) || isTier2();
      allow update, delete: if false; // Attempts are immutable
    }

    match /users/{userId}/sms_analyses/{analysisId} {
      allow read, write: if isOwner(userId);
    }
    
    // OTHER COLLECTIONS
    match /phishing_templates/{templateId} {
      allow read: if isTier2();
      allow write: if isTier1();
    }
    
    match /phishingSimulations/{simId} {
        allow read, write: if isTier2();
    }

    match /assignments/{assignmentId} {
        allow read, write: if isTier2();
    }
    
    match /reports/{reportId} {
      allow read, write: if isTier2();
    }

    match /subscription_plans/{planId} {
      allow read: if request.auth.uid != null;
      allow write: if isTier0();
    }

    match /compliance_rules/{ruleId} {
      allow read: if request.auth.uid != null;
      allow write: if isTier0();
    }
    
    match /risk_scores/{userId} {
      allow read: if isOwner(userId) || isTier2();
      allow write: if isTier2();
    }
  }
}

  